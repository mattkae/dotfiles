{
	"layer": "top",
	"position": "top",
	"margin": "4",
  "spacing": "4",

	"modules-left": [
		"sway/mode",
		"sway/workspaces",
		"sway/window",
		"custom/media"
	],

	"modules-right": [
		"pulseaudio",
		"network",
		"memory",
		"cpu",
		"temperature",
		"battery",
    "custom/weather",
		"tray",
		"clock#date",
		"clock#time"
	],

	// Modules

  "custom/media": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/media.sh",
    "interval": 3,
    "on-click": "playerctl play-pause",
  },

  "custom/weather": {
    "format": "{} ´őç",
    "exec": "~/.config/waybar/scripts/weather.sh",
    "interval": 600,
    //"on-click": "bash -e ~/.config/waybar/scripts/weather-details.sh"
  },

	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "´âž {capacity}% ({time})",
		"format-charging-full": "´âž {capacity}%",
		"format-full": "{icon} {capacity}%",
		"format-alt": "{icon} {power}W",
		"format-icons": [
			"´ëä",
			"´ëâ",
			"´ëé",
			"´ëü",
			"´ëÇ"
		],
		"tooltip": false
	},

	"clock#time": {
		"interval": 10,
		"format": "{:%H:%M}",
		"tooltip": false
	},

	"clock#date": {
		"interval": 20,
		"format": "{:%e %b %Y}",
		"tooltip": false
		//"tooltip-format": "{:%e %B %Y}"
	},

	"cpu": {
		"interval": 5,
		"tooltip": false,
		"format": "´őŤ {usage}%",
		"format-alt": "´őŤ {load}",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},


	"memory": {
		"interval": 5,
		"format": "{used:0.1f}G/{total:0.1f}G",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": false
	},

	"network": {
		"interval": 5,
		"format-wifi": "´çź {essid} ({signalStrength}%)",
		"format-ethernet": "{ifname}",
		"format-disconnected": "No connection",
		"format-alt": "{ipaddr}/{cidr}",
		"tooltip": false
	},

	"sway/mode": {
		"format": "{}",
		"tooltip": false
	},

	"sway/window": {
		"format": "{}",
		"max-length": 30,
		"tooltip": false
	},

	"sway/workspaces": {
		"disable-scroll-wraparound": true,
		"smooth-scrolling-threshold": 4,
		"enable-bar-scroll": true,
		"format": "{name}"
	},

	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "{icon} ´Őö {volume}%",
		"format-muted": "´ÇŽ",
		"format-icons": {
			"headphone": "´Çą",
			"hands-free": "´Çą",
			"headset": "´Çą",
			"phone": "´éĽ",
			"portable": "´éĽ",
			"car": "´ć╣",
			"default": ["´Çž", "´ÇĘ"]
		},
		"scroll-step": 1,
		"on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"tooltip": false
	},

	"temperature": {
		"critical-threshold": 90,
		"interval": 5,
		"format": "{icon} {temperatureC}┬░",
		"format-icons": [
			"´őő",
			"´őŐ",
			"´őë",
			"´őł",
			"´őç"
		],
		"tooltip": false
	},

	"tray": {
		"icon-size": 18
	}
}

